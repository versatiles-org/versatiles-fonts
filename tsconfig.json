{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"types": ["node"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"erasableSyntaxOnly": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["scripts/**/*.ts"]
}
