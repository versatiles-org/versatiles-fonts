	"dependencies": {
		"fontkit": "^2.0.4",
		"subset-font": "^2.5.0"
	},
	"devDependencies": {
		"@types/fontkit": "^2.0.9",
		"@types/node": "^24.0.0",
		"prettier": "^3.9.4",
		"tsx": "^4.22.4",
		"typescript": "^5.7.0"
	}
}
