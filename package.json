{
	"name": "versatiles-fonts",
	"version": "0.0.0",
	"private": true,
	"description": "Free font glyphs tailored for map rendering.",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"update-fonts": "tsx scripts/update-fonts.ts",
		"typecheck": "tsc --noEmit",
